# Variables de entorno para Veri Vinos
# Copia este archivo a .env.development y rellena los valores

# URL base de WooCommerce REST API v3
VITE_WC_BASE_URL=https://tu-sitio.com/wp-json/wc/v3

# Consumer Key generada en WooCommerce → Ajustes → Avanzado → REST API
VITE_WC_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Consumer Secret
VITE_WC_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
